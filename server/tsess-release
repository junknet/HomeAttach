#!/bin/bash
# Ensure a sane PATH: non-interactive SSH exec (e.g. JSch) may hand us a
# minimal PATH that lacks even coreutils. Absolute-shebang + this keep us safe.
export PATH="/usr/local/sbin:/usr/local/bin:/usr/bin:/bin${PATH:+:$PATH}"
# Release focus from a client owner when that client disconnects: the PC
# attach client (if any) re-asserts its own terminal size.
set -euo pipefail

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
state_command="$script_dir/tsess-state"
[ -x "$state_command" ] || state_command=tsess-state

if [ "$#" -ne 2 ]; then
    echo "usage: tsess-release <session> <owner>" >&2
    exit 2
fi

exec "$state_command" release "$1" "$2"
