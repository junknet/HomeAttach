#!/usr/bin/env bash

# SSH configuration + QR-code generator for HomeAttach.
#
# Default   : ensure a dedicated HomeAttach keypair exists and is authorized,
#             then print the connection config as a terminal QR code.
# --rotate  : revoke every previously authorized HomeAttach key, generate a
#             fresh keypair, authorize it, and print the new QR. The old private
#             key stops working the moment it leaves authorized_keys, so rescan
#             the new code in the app afterwards.
# --host H  : embed hostname/domain H instead of auto-detecting a raw address.
#             Use this with a dynamic-DNS domain so the QR never goes stale
#             when the PC's IPv6 rotates — auto-detection picks a point-in-time
#             address that breaks the moment the address it names changes.
#
# Keys are tagged with the comment "homeattach-android-app"; revocation matches
# on that tag, so it cleans up prior keys even if the key file was replaced.

set -euo pipefail

KEY_PATH="$HOME/.ssh/id_ed25519_homeattach"
KEY_COMMENT="homeattach-android-app"
AUTHORIZED="$HOME/.ssh/authorized_keys"
USER_NAME=$(whoami)

ROTATE=0
HOST_OVERRIDE=""
while [ $# -gt 0 ]; do
    case "$1" in
        --rotate) ROTATE=1; shift ;;
        --host) HOST_OVERRIDE="${2:?--host requires a value}"; shift 2 ;;
        *) echo "Unknown argument: $1" >&2; exit 1 ;;
    esac
done

mkdir -p "$HOME/.ssh"
chmod 700 "$HOME/.ssh"
touch "$AUTHORIZED"
chmod 600 "$AUTHORIZED"

revoke_homeattach_keys() {
    # Revoke by BOTH the comment tag and the exact key material of the current
    # key file, so a prior key is removed even if its comment was rewritten.
    local old_field="${1:-}"
    local before after tmp
    before=$(wc -l < "$AUTHORIZED" 2>/dev/null || echo 0)
    tmp=$(mktemp)
    awk -v c=" $KEY_COMMENT\$" -v f="$old_field" '
        $0 ~ c { next }
        f != "" && index($0, f) { next }
        { print }
    ' "$AUTHORIZED" > "$tmp" || true
    cat "$tmp" > "$AUTHORIZED"
    rm -f "$tmp"
    after=$(wc -l < "$AUTHORIZED" 2>/dev/null || echo 0)
    if [ "$before" -ne "$after" ]; then
        echo "Revoked $((before - after)) previously authorized HomeAttach key(s)."
    else
        echo "No prior HomeAttach key was authorized (nothing to revoke)."
    fi
}

if [ "$ROTATE" -eq 1 ]; then
    echo "Rotating HomeAttach SSH key..."
    OLD_FIELD=""
    [ -f "${KEY_PATH}.pub" ] && OLD_FIELD=$(awk '{print $2}' "${KEY_PATH}.pub")
    revoke_homeattach_keys "$OLD_FIELD"
    rm -f "$KEY_PATH" "${KEY_PATH}.pub"
    ssh-keygen -t ed25519 -f "$KEY_PATH" -N "" -C "$KEY_COMMENT"
    cat "${KEY_PATH}.pub" >> "$AUTHORIZED"
    echo "New key generated and authorized."
elif [ ! -f "$KEY_PATH" ]; then
    echo "Generating new dedicated SSH keypair for HomeAttach..."
    ssh-keygen -t ed25519 -f "$KEY_PATH" -N "" -C "$KEY_COMMENT"
    cat "${KEY_PATH}.pub" >> "$AUTHORIZED"
    echo "Key created and added to authorized_keys."
else
    # Key exists but may have been de-authorized; make sure it is present.
    if ! grep -qF "$(cut -d' ' -f2 "${KEY_PATH}.pub")" "$AUTHORIZED" 2>/dev/null; then
        cat "${KEY_PATH}.pub" >> "$AUTHORIZED"
        echo "Re-authorized existing HomeAttach key."
    fi
fi

if [ -n "$HOST_OVERRIDE" ]; then
    IP="$HOST_OVERRIDE"
else
    # Detect a stable global IPv6: prefer the address whose preferred_lft
    # equals its valid_lft. A SLAAC privacy-extension (temporary) address
    # always reports a shorter preferred_lft than valid_lft — the kernel
    # does not reliably tag it with the literal word "temporary" in `ip addr`
    # output, so lifetimes are the only dependable signal. Falls back to IPv4.
    IP=$(ip -o -6 addr show scope global 2>/dev/null | awk '
        {
            addr = ""; valid = ""; pref = ""
            for (i = 1; i <= NF; i++) {
                if ($i == "inet6") { addr = $(i + 1); sub(/\/.*/, "", addr) }
                if ($i == "valid_lft") { v = $(i + 1); sub(/sec$/, "", v); valid = v }
                if ($i == "preferred_lft") { p = $(i + 1); sub(/sec$/, "", p); pref = p }
            }
            if (addr == "") next
            if (valid == pref && stable == "") stable = addr
            if (fallback == "") fallback = addr
        }
        END { print (stable != "") ? stable : fallback }
    ')
    [ -n "$IP" ] || IP=$(ip -4 addr show scope global 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1 | head -n1)
fi
if [ -z "$IP" ]; then
    echo "Error: could not detect a global-scope network address (use --host to set one explicitly)." >&2
    exit 1
fi

# Full config as YAML; the private key rides in a block scalar, so the PEM
# survives byte-for-byte with no escaping games.
YAML_CONFIG="host: $IP
port: 22
username: $USER_NAME
private_key: |
$(sed 's/^/  /' "$KEY_PATH")"

echo "=========================================================="
echo " HomeAttach Configurator"
echo "   username   : $USER_NAME"
echo "   address    : $IP"
echo "   key        : $KEY_PATH"
echo "=========================================================="
echo ""

if command -v qrencode >/dev/null 2>&1; then
    echo "Scan this in the app: Settings -> Scan QR Code"
    echo ""
    printf '%s' "$YAML_CONFIG" | qrencode -t utf8
else
    echo "'qrencode' not installed (sudo apt install qrencode) to render a QR."
    echo "Raw config YAML (paste into the app if needed):"
    echo ""
    echo "$YAML_CONFIG"
fi
