HOMEATTACH_UPDATE_OWNER=your-github-owner
HOMEATTACH_UPDATE_REPO=HomeAttach

# Local connection notes only. The Android app saves these from Settings into
# encrypted app storage; this file is ignored and is not read by the public APK.
HOMEATTACH_HOME_HOST=example.com
HOMEATTACH_HOME_PORT=22
HOMEATTACH_HOME_USERNAME=your-linux-user
HOMEATTACH_HOME_PRIVATE_KEY_FILE=/path/to/id_ed25519_homeattach

# Local release signing only. Do not commit real values.
HOMEATTACH_RELEASE_STORE_FILE=keystores/homeattach-release.jks
HOMEATTACH_RELEASE_STORE_PASSWORD=
HOMEATTACH_RELEASE_KEY_ALIAS=homeattach
HOMEATTACH_RELEASE_KEY_PASSWORD=
