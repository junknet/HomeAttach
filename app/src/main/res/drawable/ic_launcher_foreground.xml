<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp" android:height="108dp"
    android:viewportWidth="108" android:viewportHeight="108">
  <group android:scaleX="1.1" android:scaleY="1.1" android:pivotX="54" android:pivotY="54">
    <!-- 六边形外框，带有精致的渐变 -->
    <path
        android:pathData="M54,22 L82,38.16 L82,70.5 L54,86.66 L26,70.5 L26,38.16 Z"
        android:strokeWidth="3.5"
        android:strokeLineJoin="round"
        android:strokeLineCap="round">
      <aapt:attr name="android:strokeColor">
        <gradient android:startX="26" android:startY="22" android:endX="82" android:endY="86.66" android:type="linear">
          <item android:offset="0" android:color="#00B0FF"/>
          <item android:offset="1" android:color="#00E676"/>
        </gradient>
      </aapt:attr>
    </path>
    <!-- 内部的终端提示符 >，同样带有精致的渐变 -->
    <path
        android:pathData="M44,44 L54,54 L44,64"
        android:strokeWidth="4"
        android:strokeLineJoin="round"
        android:strokeLineCap="round">
      <aapt:attr name="android:strokeColor">
        <gradient android:startX="44" android:startY="44" android:endX="54" android:endY="64" android:type="linear">
          <item android:offset="0" android:color="#00B0FF"/>
          <item android:offset="1" android:color="#00E676"/>
        </gradient>
      </aapt:attr>
    </path>
    <!-- 内部的终端下划线光标 _ -->
    <path
        android:pathData="M59,64 L71,64"
        android:strokeWidth="4"
        android:strokeLineJoin="round"
        android:strokeLineCap="round">
      <aapt:attr name="android:strokeColor">
        <gradient android:startX="59" android:startY="64" android:endX="71" android:endY="64" android:type="linear">
          <item android:offset="0" android:color="#00B0FF"/>
          <item android:offset="1" android:color="#00E676"/>
        </gradient>
      </aapt:attr>
    </path>
  </group>
</vector>
